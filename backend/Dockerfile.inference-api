# Multi-stage build for Inference API (AWS Bedrock AgentCore Runtime)
# Platform: linux/arm64 required for AgentCore Runtime
# Pin base image to digest for reproducible builds
FROM --platform=linux/arm64 python:3.13-slim@sha256:739e7213785e88c0f702dcdc12c0973afcbd606dbf021a589cab77d6b00b579d AS builder

# Install uv (pinned to specific version for reproducibility)
COPY --from=ghcr.io/astral-sh/uv:0.7.12 /uv /uvx /bin/

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc=4:14.2.0-1 \
    g++=4:14.2.0-1 \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files first (layer caching)
COPY backend/pyproject.toml backend/README.md ./
COPY backend/uv.lock ./

# Install dependencies only from the locked versions
# --frozen: pure replay of lock file, no resolution
# --extra agentcore: include the agentcore optional dependency group
# --no-install-project: deps only first for layer caching
# --no-dev: exclude development dependencies
# --no-editable: non-editable install for production
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --extra agentcore --extra bidi --no-install-project --no-dev --no-editable

# Copy source code and install the project itself
COPY backend/src ./src
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --extra agentcore --extra bidi --no-dev --no-editable

# Production stage
FROM --platform=linux/arm64 python:3.13-slim@sha256:739e7213785e88c0f702dcdc12c0973afcbd606dbf021a589cab77d6b00b579d

WORKDIR /app

# Install runtime dependencies (curl required for HEALTHCHECK)
RUN apt-get update && apt-get install -y \
    curl=8.14.1-2+deb13u2 \
    && rm -rf /var/lib/apt/lists/*

# Copy the virtual environment from builder
COPY --from=builder /app/.venv /app/.venv

# Copy application code
COPY backend/src /app/src

# Create necessary directories
RUN mkdir -p /app/output /app/uploads /app/generated_images

# Create non-root user for security (AgentCore Runtime best practice)
RUN useradd -m -u 1000 -s /bin/bash bedrock_agentcore && \
    chown -R bedrock_agentcore:bedrock_agentcore /app

# Switch to non-root user
USER bedrock_agentcore

# Version injection (defaults to "unknown" if not provided via --build-arg)
ARG APP_VERSION=unknown
ENV APP_VERSION=${APP_VERSION}

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src
ENV PATH="/app/.venv/bin:$PATH"

# Set AWS region environment variables (required for AgentCore Runtime)
# ARG provides the build-time default; ENV bakes it into the image.
# At runtime, ECS task definition or docker run -e overrides these.
ARG AWS_REGION=us-east-1
ENV AWS_REGION=${AWS_REGION}
ENV AWS_DEFAULT_REGION=${AWS_REGION}

# Expose port 8080 (AgentCore Runtime standard port)
EXPOSE 8080

# Health check for /ping endpoint (AgentCore Runtime standard)
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/ping || exit 1

# Run the application with ADOT auto-instrumentation for AgentCore observability
# opentelemetry-instrument wraps the app to emit traces, metrics, and logs via OTLP
CMD ["opentelemetry-instrument", "uvicorn", "apis.inference_api.main:app", "--host", "0.0.0.0", "--port", "8080"]
